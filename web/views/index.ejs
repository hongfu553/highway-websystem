<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>移動式分隔島 - 首頁</title>
    <!-- Tocas UI 套件 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tocas/5.0.1/tocas.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/tocas/5.0.1/tocas.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="ts-app-layout is-fullscreen is-horizontal">
        <%- include('partials/sidebar', { user: user, active: 'main' }) %>

        <div class="ts-container is-narrow has-vertically-padded-large">
            <div class="ts-header is-large is-heavy">儀表板</div>
            <div class="ts-text is-secondary">檢視系統狀態。</div>
            <div class="ts-grid is-relaxed is-3-columns has-top-spaced-large">
                <div class="column">
                    <div class="ts-box">
                        <div class="ts-content">
                            <div class="ts-statistic">
                                <div class="value">96.63 km/h</div>
                            </div>
                            高速公路最高車速
                        </div>
                        <div class="symbol">
                            <span class="ts-icon is-wheelchair-move-icon"></span>
                        </div>
                    </div>
                </div>
                <div class="column">
                    <div class="ts-box">
                        <div class="ts-content">
                            <div class="ts-statistic">
                                <div class="value">2</div>
                            </div>
                            今日車禍數
                        </div>
                        <div class="symbol">
                            <span class="ts-icon is-car-burst-icon"></span>
                        </div>
                    </div>
                </div>
                <div class="column">
                    <div class="ts-box">
                        <div class="ts-content">
                            <div class="ts-statistic">
                                <div class="value">17 km/h</div>
                            </div>
                            高速公路最低車速
                        </div>
                        <div class="symbol">
                            <span class="ts-icon is-wheelchair-icon"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="ts-divider is-section has-top-spaced-large"></div>
            <div class="ts-box" style="display: flex; flex-direction: column; align-items: center;">
                <div class="ts-header is-heavy">即時交通路況</div>
                <!-- 地圖顯示 -->
                <div class="map-container" style="width: 100%; overflow: hidden; border-radius: 8px;">
                    <iframe id="traffic-map"
                        src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d1938037.8510976478!2d120.29374776101614!3d23.721812774012847!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1szh-TW!2stw!4v1732003090233!5m2!1szh-TW!2stw"
                        width="100%"
                        height="450"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</body>
</html>